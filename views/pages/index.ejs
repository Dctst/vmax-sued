      </div>
    </div>
  </div>
</section>


<!-- ============================================
     SEKTION 3 — DAS PROBLEM / DIE HALTUNG
     ============================================ -->
<section class="section-spacing" id="haltung">
  <div class="container-vmax">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <!-- Linke Spalte: Headline -->
      <div class="lg:col-span-5" data-reveal>
        <span class="label-caps text-accent block mb-4">Unsere Haltung</span>
        <h2 class="font-display text-3xl md:text-4xl lg:text-display-section font-medium uppercase tracking-tight leading-[1.05]">
          Warum die meisten Tunings enttäuschen.
        </h2>
      </div>

      <!-- Rechte Spalte: Editorial-Text -->
      <div class="lg:col-span-7 lg:pt-12" data-reveal data-delay="150">
        <div class="space-y-6 text-text-secondary text-lg leading-relaxed">
          <p>
            Eine Software aus dem Netz herunterladen, auf dem Parkplatz aufspielen, Feierabend&nbsp;— das ist kein Tuning. Das ist Glücksspiel mit dem Motor Ihres Fahrzeugs.
          </p>
          <p>
            Bei VMAX Süd wird jedes Fahrzeug einzeln abgestimmt. Kein Fernzugriff, keine Paketlösung. Ihr Wagen steht bei uns, wir messen, wir optimieren, wir testen&nbsp;— und Sie bekommen eine TÜV-konforme Leistungssteigerung mit Nachweis.
          </p>
          <p>
            So macht das seit 1997 die VMAX Performance Gruppe. So machen wir das in&nbsp;Westendorf.
          </p>
        </div>

        <!-- Akzent-Linie + Signature -->
        <div class="mt-10 pt-8 border-t border-border-subtle flex items-center gap-6">
          <div class="w-12 h-px bg-accent"></div>
          <div>
            <p class="text-text-primary font-medium">Stefan Jung</p>
            <p class="text-text-muted text-sm">Inhaber, VMAX Süd</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- Platzhalter: Sektionen 4-10 folgen in Deliverable 4-5 -->
<section class="py-24">
  <div class="container-vmax text-center text-text-muted">
    <p class="label-caps">Sektionen 4–10 folgen</p>
  </div>
</section>


<!-- ============================================
     SCROLL REVEAL + COUNTER ANIMATION
     ============================================ -->
<script>
(function() {
  // Scroll Reveal
  const revealElements = document.querySelectorAll('[data-reveal]');

  function reveal() {
    revealElements.forEach(function(el) {
      const top = el.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;

      if (top < windowHeight - 60) {
        const delay = parseInt(el.dataset.delay || 0);
        setTimeout(function() {
          el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, delay);
      }
    });
  }

  // Initial state
  revealElements.forEach(function(el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
  });

  // Hero elements reveal on load
  setTimeout(reveal, 100);
  window.addEventListener('scroll', reveal, { passive: true });

  // Counter Animation
  const counters = document.querySelectorAll('[data-counter]');
  let countersAnimated = false;

  function animateCounters() {
    if (countersAnimated) return;

    counters.forEach(function(counter) {
      const rect = counter.getBoundingClientRect();
      if (rect.top > window.innerHeight) return;

      countersAnimated = true;
      const target = parseInt(counter.dataset.counter);
      const valueEl = counter.querySelector('.counter-value');
      if (!valueEl) return;

      const duration = 2000;
      const start = performance.now();

      function update(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        // Ease out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        valueEl.textContent = Math.round(target * eased);

        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }

      requestAnimationFrame(update);
    });
  }

  window.addEventListener('scroll', animateCounters, { passive: true });

  // Ken Burns on hero
  var heroImg = document.querySelector('.hero-bg-image');
  if (heroImg) {
    heroImg.style.transition = 'transform 15s ease-out';
    setTimeout(function() {
      heroImg.style.transform = 'scale(1.08)';
    }, 200);
  }
})();
</script>

<%- include('../layouts/end') %>

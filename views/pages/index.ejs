<!-- ============================================
     ANIMATIONS
     ============================================ -->
<script>
(function() {
  // --- Scroll Reveal with stagger ---
  var revealElements = document.querySelectorAll('[data-reveal]');

  function reveal() {
    revealElements.forEach(function(el) {
      if (el.getBoundingClientRect().top < window.innerHeight - 40) {
        var delay = parseInt(el.dataset.delay || 0);
        setTimeout(function() {
          el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, delay);
      }
    });
  }

  revealElements.forEach(function(el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
  });

  setTimeout(reveal, 80);
  window.addEventListener('scroll', reveal, { passive: true });

  // --- CountUp for [data-counter] ---
  var counterEls = document.querySelectorAll('[data-counter]');
  var countersAnimated = false;

  function animateCounters() {
    if (countersAnimated) return;
    counterEls.forEach(function(counter) {
      if (counter.getBoundingClientRect().top > window.innerHeight) return;
      countersAnimated = true;
      var target = parseInt(counter.dataset.counter);
      var valueEl = counter.querySelector('.counter-value');
      if (!valueEl) return;
      countUp(valueEl, target, 2000);
    });
  }

  function countUp(el, target, duration, prefix) {
    var start = performance.now();
    prefix = prefix || '';
    function update(now) {
      var progress = Math.min((now - start) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = prefix + Math.round(target * eased);
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  window.addEventListener('scroll', animateCounters, { passive: true });

  // --- Hero background dyno draw-in ---
  var heroDynoBg = document.getElementById('hero-dyno-bg');
  if (heroDynoBg) {
    setTimeout(function() {
      heroDynoBg.style.transition = 'stroke-dashoffset 2.5s ease-out';
      heroDynoBg.style.strokeDashoffset = '0';
    }, 400);
  }

  // --- Panel dyno curve (scroll-triggered) ---
  var dynoCurve = document.getElementById('dyno-stage');
  var dynoLabel = document.getElementById('dyno-label');
  var dynoAnimated = false;

  function animateDyno() {
    if (dynoAnimated || !dynoCurve) return;
    if (window.pageYOffset > 80) {
      dynoAnimated = true;
      dynoCurve.style.transition = 'stroke-dashoffset 2s ease-out';
      dynoCurve.style.strokeDashoffset = '0';
      if (dynoLabel) {
        setTimeout(function() {
          dynoLabel.style.transition = 'opacity 0.5s ease';
          dynoLabel.style.opacity = '1';
        }, 1600);
      }
    }
  }

  window.addEventListener('scroll', animateDyno, { passive: true });
})();
</script>


<%- include('../layouts/main') %>

<!-- ============================================
     SEKTION 1 — HERO
     Schwarzer Grund + Dyno-Hintergrund + Tech-Panel
     ============================================ -->
<section class="relative min-h-screen flex items-center overflow-hidden" id="hero">
  <!-- Background: Dyno curve as ambient element -->
  <div class="absolute inset-0" aria-hidden="true">
    <svg viewBox="0 0 1440 600" class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice">
      <path d="M0,500 C200,490 400,400 600,300 C800,200 1000,100 1200,60 C1300,40 1400,45 1440,50"
            fill="none" stroke="#F59E0B" stroke-width="2" opacity="0.08"
            id="hero-dyno-bg" style="stroke-dasharray: 1800; stroke-dashoffset: 1800;"/>
    </svg>
  </div>

  <!-- Coordinate markers -->
  <div class="absolute top-6 left-6 lg:top-8 lg:left-12 z-20 font-micro text-[9px] text-text-muted/30 tracking-widest">
    48.4267°N / 10.8742°E
  </div>
  <div class="absolute top-6 right-6 lg:top-8 lg:right-12 z-20 font-micro text-[9px] text-text-muted/30 tracking-widest">
    VMAX-SUED/WSDF
  </div>

  <div class="container-vmax relative z-20 py-32 lg:py-40">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Links: Headline + CTAs (60%) -->
      <div class="lg:col-span-7">
        <!-- Eyebrow -->
        <p class="font-micro text-micro uppercase text-text-muted/60 tracking-[0.15em] mb-6 opacity-0" data-reveal>
          VMAX SÜD · EST. 2011 · WESTENDORF
        </p>

        <!-- Headline-Varianten:
             Alt: "LEISTUNG ZUM ANFASSEN."
             Option B: "Gemessen. Geprüft. Eingetragen."
             Option C: "Wo Leistung Papiere hat."
             Aktiv: "Jede Zahl. Eingetragen." -->
        <h1 class="font-display text-display-hero italic leading-[1.05] opacity-0" data-reveal data-delay="80">
          Jede Zahl.<br>Eingetragen.
        </h1>

        <p class="mt-6 text-lg text-text-secondary max-w-lg opacity-0" data-reveal data-delay="160">
          Einzelabstimmung. TÜV-Eintragung. Prüftechnik aus Schwaben&nbsp;— für&nbsp;Deutschland.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-10 opacity-0" data-reveal data-delay="240">
          <a href="/kontakt" class="btn-primary">
            Termin anfragen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#leistungen" class="btn-ghost">
            Leistungsspektrum
          </a>
        </div>

        <!-- Trust markers -->
        <div class="mt-8 flex flex-wrap items-center gap-x-3 gap-y-1 font-micro text-[9px] text-text-muted/50 uppercase tracking-[0.1em] opacity-0" data-reveal data-delay="320">
          <span>TÜV-Eintragung</span><span class="text-accent/40">·</span>
          <span>Einzelabstimmung</span><span class="text-accent/40">·</span>
          <span>Prüfstand</span><span class="text-accent/40">·</span>
          <span>Seit 2011</span>
        </div>
      </div>

      <!-- Rechts: Technisches Panel (40%) -->
      <div class="lg:col-span-5 opacity-0" data-reveal data-delay="200">
        <div class="border border-border-subtle bg-bg-primary/50 backdrop-blur-sm relative">
          <!-- Corner brackets -->
          <div class="absolute -top-px -left-px w-5 h-5 border-t border-l border-border-strong"></div>
          <div class="absolute -top-px -right-px w-5 h-5 border-t border-r border-border-strong"></div>
          <div class="absolute -bottom-px -left-px w-5 h-5 border-b border-l border-border-strong"></div>
          <div class="absolute -bottom-px -right-px w-5 h-5 border-b border-r border-border-strong"></div>

          <!-- Panel Header -->
          <div class="px-6 py-3 border-b border-border-subtle flex items-center justify-between">
            <span class="font-micro text-[9px] text-text-muted uppercase tracking-[0.12em]">Leistungsnachweis · #A847</span>
            <span class="w-1.5 h-1.5 rounded-full bg-accent-success animate-glow-pulse"></span>
          </div>

          <!-- Panel Content -->
          <div class="p-6 space-y-5">
            <!-- Vorher/Nachher -->
            <div>
              <p class="font-micro text-[9px] text-text-muted uppercase tracking-[0.12em] mb-3">Beispiel · VW Golf 7 GTI · 2.0 TSI</p>
              <div class="flex items-end gap-4">
                <div>
                  <p class="font-micro text-[8px] text-text-muted uppercase tracking-widest">Serie</p>
                  <p class="font-mono text-2xl text-text-secondary">230 <span class="text-xs text-text-muted">PS</span></p>
                </div>
                <svg class="w-6 h-6 text-accent mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                <div>
                  <p class="font-micro text-[8px] text-accent uppercase tracking-widest">Stage 1</p>
                  <p class="font-mono text-2xl text-text-primary">300 <span class="text-xs text-text-muted">PS</span></p>
                </div>
                <div class="ml-auto">
                  <p class="font-mono text-lg text-accent">+70</p>
                  <p class="font-micro text-[8px] text-text-muted uppercase">PS Gain</p>
                </div>
              </div>
            </div>

            <!-- Mini Dyno Curve -->
            <div class="border-t border-border-subtle pt-4">
              <svg viewBox="0 0 300 60" class="w-full h-auto" aria-hidden="true">
                <path d="M0,50 C40,48 80,42 120,34 C160,26 200,20 240,18 C270,17 290,18 300,19" fill="none" stroke="#3A3A3A" stroke-width="1" stroke-dasharray="4,3"/>
                <path d="M0,50 C40,46 80,36 120,24 C160,13 200,6 240,3 C270,1 290,2 300,3" fill="none" stroke="#F59E0B" stroke-width="1.5" stroke-linecap="round"
                      id="dyno-stage" style="stroke-dasharray: 380; stroke-dashoffset: 380;"/>
                <text x="290" y="24" fill="#6B6B6B" font-size="7" font-family="Space Mono" text-anchor="end">SERIE</text>
                <text x="290" y="8" fill="#F59E0B" font-size="7" font-family="Space Mono" text-anchor="end" id="dyno-label" style="opacity:0">STG1</text>
              </svg>
            </div>

            <!-- TÜV Status -->
            <div class="flex items-center justify-between pt-2 border-t border-border-subtle">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-success"></span>
                <span class="font-micro text-[9px] text-accent-success uppercase tracking-[0.1em]">TÜV-eingetragen</span>
              </div>
              <span class="font-micro text-[8px] text-text-muted/50 tracking-wider">Gutachten 4821/24</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 text-text-muted/40 opacity-0" data-reveal data-delay="500">
    <span class="font-micro text-[8px] tracking-[0.25em] uppercase">scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-text-muted/40 to-transparent"></div>
  </div>
</section>


<!-- Section marker -->
<div class="section-marker py-4">— 001 —</div>

<!-- ============================================
     SEKTION 2 — KENNZAHLEN (Status-Monitor)
     ============================================ -->
<section class="relative z-30 bg-bg-primary" id="kennzahlen">
  <!-- Monitor Header -->
  <div class="border-t border-border-subtle">
    <p class="font-micro text-[8px] text-text-muted/30 tracking-[0.2em] uppercase text-center py-3">
      · · · VMAX SÜD STATUS MONITOR · · ·
    </p>
  </div>

  <div class="border-y border-border-subtle relative">
    <!-- Corner brackets -->
    <div class="absolute -top-px -left-px w-5 h-5 border-t border-l border-border-strong pointer-events-none hidden lg:block"></div>
    <div class="absolute -top-px -right-px w-5 h-5 border-t border-r border-border-strong pointer-events-none hidden lg:block"></div>
    <div class="absolute -bottom-px -left-px w-5 h-5 border-b border-l border-border-strong pointer-events-none hidden lg:block"></div>
    <div class="absolute -bottom-px -right-px w-5 h-5 border-b border-r border-border-strong pointer-events-none hidden lg:block"></div>

    <div class="container-vmax py-12 lg:py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

        <div data-reveal>
          <p class="font-micro text-[8px] text-text-muted/40 uppercase tracking-[0.15em] mb-2">Metrik 01</p>
          <p class="font-mono text-3xl lg:text-4xl font-medium text-text-primary" data-counter="80">
            <span class="counter-value">0</span><span class="text-accent">%</span>
          </p>
          <div class="w-full h-px bg-accent/30 mt-2 mb-2"></div>
          <p class="text-text-secondary text-xs">Fahrzeugabdeckung</p>
          <div class="flex items-center gap-1.5 mt-2">
            <span class="w-1 h-1 rounded-full bg-accent-success animate-glow-pulse"></span>
            <span class="font-micro text-[8px] text-accent-success/70 uppercase tracking-wider">Active</span>
          </div>
        </div>

        <div data-reveal data-delay="80">
          <p class="font-micro text-[8px] text-text-muted/40 uppercase tracking-[0.15em] mb-2">Metrik 02</p>
          <p class="font-mono text-3xl lg:text-4xl font-medium text-text-primary" data-counter="28">
            <span class="counter-value">0</span><span class="text-accent">+</span>
          </p>
          <div class="w-full h-px bg-accent/30 mt-2 mb-2"></div>
          <p class="text-text-secondary text-xs">Jahre Netzwerk-Erfahrung</p>
          <div class="flex items-center gap-1.5 mt-2">
            <span class="w-1 h-1 rounded-full bg-accent-success animate-glow-pulse"></span>
            <span class="font-micro text-[8px] text-accent-success/70 uppercase tracking-wider">Verified</span>
          </div>
        </div>

        <div data-reveal data-delay="160">
          <p class="font-micro text-[8px] text-text-muted/40 uppercase tracking-[0.15em] mb-2">Metrik 03</p>
          <p class="font-mono text-3xl lg:text-4xl font-medium text-text-primary" data-counter="100">
            <span class="counter-value">0</span><span class="text-accent">%</span>
          </p>
          <div class="w-full h-px bg-accent/30 mt-2 mb-2"></div>
          <p class="text-text-secondary text-xs">Einzelabstimmung vor Ort</p>
          <div class="flex items-center gap-1.5 mt-2">
            <span class="w-1 h-1 rounded-full bg-accent-success animate-glow-pulse"></span>
            <span class="font-micro text-[8px] text-accent-success/70 uppercase tracking-wider">Active</span>
          </div>
        </div>

        <div data-reveal data-delay="240">
          <p class="font-micro text-[8px] text-text-muted/40 uppercase tracking-[0.15em] mb-2">Metrik 04</p>
          <p class="font-mono text-3xl lg:text-4xl font-medium text-text-primary">
            1<span class="text-accent">on</span>1
          </p>
          <div class="w-full h-px bg-accent/30 mt-2 mb-2"></div>
          <p class="text-text-secondary text-xs">mit Stefan Jung persönlich</p>
          <div class="flex items-center gap-1.5 mt-2">
            <span class="w-1 h-1 rounded-full bg-accent-success animate-glow-pulse"></span>
            <span class="font-micro text-[8px] text-accent-success/70 uppercase tracking-wider">Active</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>


<!-- Section marker -->
<div class="section-marker py-4">— 002 —</div>

<!-- ============================================
     SEKTION 3 — DAS PROBLEM / DIE HALTUNG
     ============================================ -->
<section class="section-spacing relative" id="haltung">
  <!-- Stamp watermark -->
  <div class="absolute top-20 right-8 lg:right-24 hidden lg:block" aria-hidden="true">
    <div class="stamp w-28 h-28 text-[7px] leading-tight text-center p-2" style="transform: rotate(-6deg)">
      <span>TÜV-CERTIFIED</span><br><span>SINCE 2011</span><br><span>WESTENDORF</span>
    </div>
  </div>

  <div class="container-vmax">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <!-- Linke Spalte: Headline -->
      <div class="lg:col-span-5" data-reveal>
        <span class="label-mono text-accent block mb-4">Unsere Haltung</span>
        <!-- Ruler line -->
        <div class="ruler-line"><% for(var i=0;i<20;i++){%><span class="tick"></span><%}%></div>
        <h2 class="font-display text-display-section italic leading-[1.05]">
          Warum die meisten Tunings enttäuschen.
        </h2>
      </div>

      <!-- Rechte Spalte: Editorial-Text -->
      <div class="lg:col-span-7 lg:pt-12" data-reveal data-delay="120">
        <div class="space-y-6 text-text-secondary text-lg leading-relaxed">
          <p>
            Eine Software aus dem Netz herunterladen, auf dem Parkplatz aufspielen, Feierabend&nbsp;— das ist kein Tuning. Das ist Glücksspiel mit dem Motor Ihres Fahrzeugs.
          </p>
          <p>
            Bei VMAX Süd wird jedes Fahrzeug einzeln abgestimmt. Kein Fernzugriff, keine Paketlösung. Ihr Wagen steht bei uns, wir messen, wir optimieren, wir testen&nbsp;— und Sie bekommen eine TÜV-konforme Leistungssteigerung mit Nachweis.
          </p>
          <p>
            So macht das seit 1997 die VMAX Performance Gruppe. So machen wir das in&nbsp;Westendorf.
          </p>
        </div>

        <div class="mt-10 pt-8 border-t border-border-subtle flex items-center gap-6">
          <div class="w-12 h-px bg-accent"></div>
          <div>
            <p class="text-text-primary font-medium">Stefan Jung</p>
            <p class="text-text-muted text-sm font-micro tracking-wider">Inhaber, VMAX Süd</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- Section marker -->
<div class="section-marker py-4">— 003 —</div>

<!-- ============================================
     SEKTION 4 — LEISTUNGSSPEKTRUM (Datenblatt-Cards)
     ============================================ -->
<section class="section-spacing bg-bg-secondary" id="leistungen">
  <div class="container-vmax">

    <!-- Section Header -->
    <div class="max-w-2xl mb-16" data-reveal>
      <div class="ruler-line"><% for(var i=0;i<15;i++){%><span class="tick"></span><%}%></div>
      <h2 class="font-display text-display-section italic leading-[1.05]">
        Was wir für Sie tun.
      </h2>
      <!-- Coordinate badge -->
      <p class="font-micro text-[8px] text-text-muted/30 tracking-widest mt-4">48.4267°N · 10.8742°E · WESTENDORF</p>
    </div>

    <!-- 2x2 Datenblatt Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <% var services = [
        { num: '01', href: '/chiptuning', title: 'Chiptuning &amp; Leistungssteigerung', desc: 'Einzelabstimmung auf dem Prüfstand — nicht aus der Dose. Jedes Kennfeld wird individuell an Ihren Motor angepasst.', specs: [['PRÜFSTANDLAUF','✓'],['TÜV-EINTRAGUNG','✓'],['DOKUMENTATION','✓'],['AB-PREIS','ab 499 €']], bar: '75%' },
        { num: '02', href: '/tuev-eintragung', title: 'TÜV-Eintragung &amp; Einzelabnahme', desc: 'Von der Begutachtung bis zum Stempel. Wir begleiten Sie durch den gesamten Eintragungsprozess.', specs: [['EINZELABNAHME','✓'],['TEILEGUTACHTEN','✓'],['GTÜ / DEKRA / TÜV','✓'],['AB-PREIS','ab 89 €']], bar: '60%' },
        { num: '03', href: '/komplettumbauten', title: 'Komplettumbauten mit StVO-Abnahme', desc: 'Vom Konzept bis zur Straßenzulassung. Auch Eigenbauten und Einzelstücke bringen wir durch die Abnahme.', specs: [['MOTORTAUSCH','✓'],['FAHRWERK','✓'],['STVO-KONFORM','✓'],['EIGENBAUTEN','✓']], bar: '90%' },
        { num: '04', href: '/b2b', title: 'B2B-Prüftechnik für Unternehmen', desc: 'Gutachten, Abgastests und Bauteilfreigaben für Tuninghersteller, Importeure und Werkstätten.', specs: [['BETRIEBSFESTIGKEIT','✓'],['ABGASTESTS','✓'],['TEILEGUTACHTEN','✓'],['NDA-FÄHIG','✓']], bar: '45%' }
      ]; %>

      <% services.forEach(function(s, i) { %>
      <a href="<%= s.href %>" class="card p-0 group relative overflow-hidden" data-reveal data-delay="<%= i * 80 %>">
        <!-- Radar indicator on hover -->
        <div class="absolute top-4 right-4 w-6 h-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
          <svg viewBox="0 0 24 24" class="w-full h-full animate-spin" style="animation-duration:3s">
            <circle cx="12" cy="12" r="10" fill="none" stroke="#2A2A2A" stroke-width="0.5"/>
            <line x1="12" y1="2" x2="12" y2="12" stroke="#F59E0B" stroke-width="0.5" opacity="0.6"/>
          </svg>
        </div>

        <!-- Header -->
        <div class="px-6 py-3 border-b border-border-subtle">
          <span class="font-micro text-[9px] text-text-muted/50 uppercase tracking-[0.12em]">Dienstleistung · <%= s.num %> / 04</span>
        </div>

        <!-- Content -->
        <div class="p-6">
          <h3 class="font-display text-display-card italic leading-tight mb-3">
            <%- s.title %>
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-6">
            <%= s.desc %>
          </p>

          <!-- Spec Sheet -->
          <div class="space-y-2 mb-6">
            <% s.specs.forEach(function(spec) { %>
            <div class="spec-row">
              <span class="spec-label"><%= spec[0] %></span>
              <span class="spec-dots"></span>
              <span class="spec-value"><%= spec[1] %></span>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="h-0.5 bg-bg-secondary">
          <div class="h-full bg-accent/40 group-hover:bg-accent transition-colors duration-500" style="width:<%= s.bar %>"></div>
        </div>
      </a>
      <% }); %>

    </div>
  </div>
</section>


<!-- ============================================
     SEKTION 5 — VAG-SPEZIALISIERUNG
     ============================================ -->

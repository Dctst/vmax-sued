<%- include('../layouts/main') %>

<!-- ============================================
     SEKTION 1 — HERO (100vh)
     ============================================ -->
<section class="relative h-screen flex items-end pb-20 lg:pb-24 overflow-hidden" id="hero">
  <!-- Background mit Ken-Burns-Effekt -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-bg-secondary hero-bg-image"
         style="background-image: url('https://images.unsplash.com/photo-1619405399517-d7fce0f13302?w=1920&q=80');
                background-size: cover; background-position: center;">
    </div>
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/60 to-bg-primary/20 z-10"></div>
    <!-- Zusätzlicher Bottom-Gradient für nahtlosen Übergang -->
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-bg-primary to-transparent z-10"></div>
  </div>

  <div class="container-vmax relative z-20">
    <!-- Trust Badge -->
    <div class="inline-flex items-center gap-2 mb-8 opacity-0" data-reveal>
      <span class="w-8 h-px bg-accent"></span>
      <span class="label-caps text-accent">Partner der VMAX Performance Gruppe · seit 1997</span>
    </div>

    <h1 class="font-display text-5xl md:text-7xl lg:text-display-hero font-medium uppercase tracking-tight leading-[0.95] opacity-0" data-reveal data-delay="100">
      Leistung<br>zum Anfassen.
    </h1>

    <p class="mt-6 text-lg md:text-body-lg text-text-secondary max-w-2xl opacity-0" data-reveal data-delay="200">
      Einzelabstimmung. TÜV-Eintragung. Prüftechnik aus Schwaben&nbsp;— für&nbsp;Deutschland.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 mt-10 opacity-0" data-reveal data-delay="300">
      <a href="/kontakt" class="btn-primary">
        Termin anfragen
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a href="#leistungen" class="btn-ghost">
        Leistungsspektrum ansehen
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 text-text-muted opacity-0" data-reveal data-delay="600">
    <span class="font-mono text-[10px] tracking-[0.2em] uppercase">scroll</span>
    <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7"/></svg>
  </div>
</section>


<!-- ============================================
     SEKTION 2 — KENNZAHLEN-BAND
     ============================================ -->

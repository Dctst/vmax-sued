<%- include('../layouts/main') %>

<!-- Hero -->
<section class="pt-32 pb-12 lg:pt-40 lg:pb-16">
  <div class="container-vmax">
    <nav class="mb-8 text-sm text-text-muted" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text-secondary transition-colors">Start</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">Galerie</span>
    </nav>
    <span class="label-caps text-accent block mb-4">Projekte</span>
    <h1 class="font-display text-4xl md:text-5xl lg:text-display-section font-medium uppercase tracking-tight leading-[1.05]">
      Galerie
    </h1>
    <p class="mt-4 text-lg text-text-secondary max-w-2xl">
      Kundenfahrzeuge, Prüfstands-Sessions und abgeschlossene Projekte. Echte Ergebnisse — kein Stock-Material.
    </p>
  </div>
</section>

<!-- Filter -->
<section class="pb-8">
  <div class="container-vmax">
    <div class="flex flex-wrap gap-2" id="gallery-filters">
      <button class="gallery-filter active px-4 py-2 text-sm font-medium border border-border-subtle bg-bg-tertiary text-text-primary transition-colors" data-filter="all">Alle</button>
      <button class="gallery-filter px-4 py-2 text-sm font-medium border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="volkswagen">Volkswagen</button>
      <button class="gallery-filter px-4 py-2 text-sm font-medium border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="audi">Audi</button>
      <button class="gallery-filter px-4 py-2 text-sm font-medium border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="seat">SEAT / CUPRA</button>
      <button class="gallery-filter px-4 py-2 text-sm font-medium border border-border-subtle text-text-muted hover:text-text-primary transition-colors" data-filter="andere">Andere</button>
    </div>
  </div>
</section>

<!-- Masonry Grid -->
<section class="pb-section-mobile lg:pb-section">
  <div class="container-vmax">
    <div class="columns-1 md:columns-2 lg:columns-3 gap-5 space-y-5" id="gallery-grid">

      <% var galleryItems = [
        { img: 'https://images.unsplash.com/photo-1609521263047-f8f205293f24?w=800&q=80', brand: 'volkswagen', label: 'VW Golf 7 GTI', desc: 'Stage 1 — +70 PS', tall: true },
        { img: 'https://images.unsplash.com/photo-1606664515524-ed2f786a0bd6?w=800&q=80', brand: 'audi', label: 'Audi RS3 8V', desc: 'Stage 2 — +120 PS', tall: false },
        { img: 'https://images.unsplash.com/photo-1616422285623-13ff0162193c?w=800&q=80', brand: 'volkswagen', label: 'VW Golf 8 R', desc: 'Stage 1 — +80 PS', tall: false },
        { img: 'https://images.unsplash.com/photo-1603584173870-7f23fdae1b7a?w=800&q=80', brand: 'audi', label: 'Audi TT RS', desc: 'Stage 1 — +60 PS', tall: true },
        { img: 'https://images.unsplash.com/photo-1552519507-da3b142c6e3d?w=800&q=80', brand: 'seat', label: 'SEAT Leon Cupra', desc: 'Stage 1 — +70 PS', tall: false },
        { img: 'https://images.unsplash.com/photo-1606611013016-969c19ba27a5?w=800&q=80', brand: 'volkswagen', label: 'VW Tiguan R', desc: 'Stage 1 — +70 PS', tall: false },
        { img: 'https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8?w=800&q=80', brand: 'seat', label: 'CUPRA Formentor VZ', desc: 'Stage 1 — +70 PS', tall: true },
        { img: 'https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=800&q=80', brand: 'andere', label: 'Prüfstand-Session', desc: 'Kennfeldoptimierung', tall: false },
        { img: 'https://images.unsplash.com/photo-1583121274602-3e2820c69888?w=800&q=80', brand: 'andere', label: 'Komplettumbau', desc: 'StVO-Abnahme bestanden', tall: false },
      ]; %>

      <% galleryItems.forEach(function(item) { %>
      <div class="gallery-item break-inside-avoid group cursor-pointer" data-brand="<%= item.brand %>">
        <div class="relative overflow-hidden border border-border-subtle bg-bg-tertiary">
          <img src="<%= item.img %>" alt="<%= item.label %>"
               class="w-full <%= item.tall ? 'h-[400px]' : 'h-[260px]' %> object-cover group-hover:scale-105 transition-transform duration-700"
               loading="lazy" decoding="async">
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
            <div>
              <p class="text-text-primary font-medium text-sm"><%= item.label %></p>
              <p class="text-text-muted text-xs mt-0.5"><%= item.desc %></p>
            </div>
          </div>
        </div>
      </div>
      <% }); %>

    </div>

    <!-- Hinweis -->
    <div class="mt-12 text-center">
      <p class="text-text-muted text-sm">Weitere Projekte folgen. Echte Kundenfahrzeuge werden nach Abschluss mit Einverständnis hinzugefügt.</p>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="fixed inset-0 z-50 bg-bg-primary/95 backdrop-blur-md hidden flex items-center justify-center" id="lightbox">
  <button class="absolute top-6 right-6 text-text-muted hover:text-text-primary transition-colors" id="lightbox-close" aria-label="Schließen">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <img src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain" id="lightbox-img">
</div>

<!-- CTA -->
<section class="py-16 border-t border-border-subtle">
  <div class="container-vmax text-center">
    <p class="text-text-secondary text-lg mb-6">Ihr Fahrzeug soll das nächste Projekt sein?</p>
    <a href="/kontakt" class="btn-primary">
      Termin anfragen
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
</section>

<script>
(function() {
  // Filter
  document.querySelectorAll('.gallery-filter').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filter = this.dataset.filter;
      document.querySelectorAll('.gallery-filter').forEach(function(b) {
        b.classList.remove('active', 'bg-bg-tertiary', 'text-text-primary');
        b.classList.add('text-text-muted');
      });
      this.classList.add('active', 'bg-bg-tertiary', 'text-text-primary');
      this.classList.remove('text-text-muted');

      document.querySelectorAll('.gallery-item').forEach(function(item) {
        if (filter === 'all' || item.dataset.brand === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });

  // Lightbox
  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');

  document.querySelectorAll('.gallery-item').forEach(function(item) {
    item.addEventListener('click', function() {
      var img = this.querySelector('img');
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', function(e) { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLightbox(); });

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }
})();
</script>

<%- include('../layouts/end') %>

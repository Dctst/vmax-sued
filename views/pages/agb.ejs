<%- include('../layouts/main') %>

<section class="pt-32 pb-12 lg:pt-40 lg:pb-16">
  <div class="container-vmax max-w-3xl">
    <h1 class="font-display text-4xl md:text-display-card font-medium uppercase tracking-tight">Allgemeine Geschäftsbedingungen</h1>
  </div>
</section>

<section class="pb-section-mobile lg:pb-section">
  <div class="container-vmax max-w-3xl">
    <div class="border border-border-subtle bg-bg-tertiary p-8 md:p-10">
      <p class="text-text-primary text-lg leading-relaxed">
        Die AGB&rsquo;s können jederzeit bei uns vor Ort eingesehen werden.
      </p>
      <div class="mt-8 pt-6 border-t border-border-subtle space-y-2 text-text-secondary text-sm font-mono">
        <p class="text-text-primary"><%= address.street %></p>
        <p class="text-text-muted text-xs"><%= address.access %></p>
        <p><%= address.zip %> <%= address.city %></p>
      </div>
      <div class="mt-4 pt-4 border-t border-border-subtle space-y-1 font-mono text-xs text-text-muted">
        <p><%= hours.weekdays %></p>
        <p><%= hours.saturday %></p>
      </div>
    </div>
  </div>
</section>

<%- include('../layouts/end') %>

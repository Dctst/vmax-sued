<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="container-vmax flex items-center justify-between h-20">

    <!-- Logo -->
    <a href="/" class="relative z-50 flex items-center gap-3 group">
      <span class="text-2xl font-display font-bold tracking-tight text-text-primary">
        VMAX <span class="text-accent">SÜD</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Hauptnavigation">
      <a href="/chiptuning" class="nav-link text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 <%= currentPath === '/chiptuning' ? 'text-text-primary' : '' %>">
        Chiptuning
      </a>
      <a href="/tuev-eintragung" class="nav-link text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 <%= currentPath === '/tuev-eintragung' ? 'text-text-primary' : '' %>">
        TÜV-Eintragung
      </a>
      <a href="/komplettumbauten" class="nav-link text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 <%= currentPath === '/komplettumbauten' ? 'text-text-primary' : '' %>">
        Komplettumbauten
      </a>
      <a href="/b2b" class="nav-link text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 <%= currentPath === '/b2b' ? 'text-text-primary' : '' %>">
        B2B
      </a>
      <a href="/galerie" class="nav-link text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 <%= currentPath === '/galerie' ? 'text-text-primary' : '' %>">
        Galerie
      </a>
      <a href="/kontakt" class="btn-primary text-sm py-3 px-6">
        Termin anfragen
      </a>
    </nav>

    <!-- Mobile Menu Toggle -->
    <button class="lg:hidden relative z-50 w-10 h-10 flex flex-col items-center justify-center gap-1.5"
            id="mobile-toggle" aria-label="Menü öffnen" aria-expanded="false">
      <span class="block w-6 h-0.5 bg-text-primary transition-all duration-300 origin-center" id="burger-top"></span>
      <span class="block w-6 h-0.5 bg-text-primary transition-all duration-300" id="burger-mid"></span>
      <span class="block w-4 h-0.5 bg-text-primary transition-all duration-300 origin-center" id="burger-bot"></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="fixed inset-0 bg-bg-primary/98 z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300" id="mobile-menu">
    <nav class="flex flex-col items-center gap-8" aria-label="Mobile Navigation">
      <a href="/" class="text-3xl font-display font-medium text-text-primary hover:text-accent transition-colors">Start</a>
      <a href="/chiptuning" class="text-3xl font-display font-medium text-text-primary hover:text-accent transition-colors">Chiptuning</a>
      <a href="/tuev-eintragung" class="text-3xl font-display font-medium text-text-primary hover:text-accent transition-colors">TÜV-Eintragung</a>
      <a href="/komplettumbauten" class="text-3xl font-display font-medium text-text-primary hover:text-accent transition-colors">Komplettumbauten</a>
      <a href="/b2b" class="text-3xl font-display font-medium text-text-primary hover:text-accent transition-colors">B2B</a>
      <a href="/galerie" class="text-3xl font-display font-medium text-text-primary hover:text-accent transition-colors">Galerie</a>
      <a href="/kontakt" class="btn-primary text-lg mt-4">Termin anfragen</a>
    </nav>
    <div class="absolute bottom-12 text-text-muted text-sm">
      <a href="tel:<%= phone %>" class="hover:text-accent transition-colors"><%= phone %></a>
    </div>
  </div>
</header>

<script>
  // Header scroll effect
  (function() {
    const header = document.getElementById('site-header');
    let lastScroll = 0;

    window.addEventListener('scroll', function() {
      const currentScroll = window.pageYOffset;

      if (currentScroll > 80) {
        header.classList.add('bg-bg-primary/95', 'backdrop-blur-md', 'border-b', 'border-border-subtle');
      } else {
        header.classList.remove('bg-bg-primary/95', 'backdrop-blur-md', 'border-b', 'border-border-subtle');
      }

      lastScroll = currentScroll;
    }, { passive: true });

    // Mobile menu
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    const burgerTop = document.getElementById('burger-top');
    const burgerMid = document.getElementById('burger-mid');
    const burgerBot = document.getElementById('burger-bot');
    let isOpen = false;

    toggle.addEventListener('click', function() {
      isOpen = !isOpen;
      toggle.setAttribute('aria-expanded', isOpen);

      if (isOpen) {
        menu.classList.remove('opacity-0', 'pointer-events-none');
        menu.classList.add('opacity-100');
        burgerTop.classList.add('rotate-45', 'translate-y-[4px]');
        burgerMid.classList.add('opacity-0');
        burgerBot.classList.add('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.add('opacity-0', 'pointer-events-none');
        menu.classList.remove('opacity-100');
        burgerTop.classList.remove('rotate-45', 'translate-y-[4px]');
        burgerMid.classList.remove('opacity-0');
        burgerBot.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
        document.body.style.overflow = '';
      }
    });
  })();
</script>
